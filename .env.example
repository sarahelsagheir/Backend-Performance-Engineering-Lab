# Runtime database credentials
DB_HOST=mysql
MYSQL_DATABASE=bagisto
MYSQL_TESTING_DATABASE=bagisto_testing
MYSQL_PASSWORD=root

# Mail settings used by the Bagisto installer
MAIL_HOST=mailpit
MAIL_PORT=1025

# nginx-php port mappings
NGINX_HTTP_PORT=80
NGINX_MYSQL_PORT=3306

# apache-php port mappings
APACHE_HTTP_PORT=80
APACHE_MYSQL_PORT=3306

# litespeed-php port mappings
LITESPEED_HTTP_PORT=80
LITESPEED_MYSQL_PORT=3306

# Shared service port mappings
VITE_PORT=5173
PHPMYADMIN_PORT=3030
MAILPIT_WEB_PORT=8025
MAILPIT_SMTP_PORT=1025
